{
  "hive_id": "summarizer",
  "impl_id": "impl_v1",
  "mutable_genes": {
    "temperature": {
      "gene_type": "Float",
      "min": 0.0,
      "max": 0.8,
      "step": 0.1
    },
    "tool_order": {
      "gene_type": "Sequence",
      "options": ["run_script"]
    },
    "prompt_template": {
      "gene_type": "Enum",
      "options": ["default", "compact"]
    }
  },
  "immutable_fields": [
    "capability",
    "input_schema_version",
    "output_schema_version",
    "entrypoint"
  ],
  "mutation_policy": {
    "max_mutations_per_generation": 2,
    "allow_component_swap": true,
    "allow_prompt_rewrite": true,
    "allow_freeform_code_edit": false
  }
}
